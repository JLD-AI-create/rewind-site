<!DOCTYPE html>
<html>
<head>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>REWIND Preview</title>
<style>
body {margin:0;background:#0a0a0a;color:#fff;font-family:Arial;}
.hero {height:80vh;display:flex;flex-direction:column;justify-content:flex-end;padding:20px;border-bottom:4px solid red;}
.hero h1 {font-size:60px;margin:0;font-style:italic;}
.section {padding:20px;}
.card {border:1px solid #333;padding:20px;margin-bottom:15px;cursor:pointer;}
.card:hover {background:#111;}
.overlay {
  position:fixed;top:0;left:0;width:100%;height:100%;
  background:black;display:none;padding:20px;overflow:auto;
}
.close {position:fixed;top:10px;right:10px;}
</style>
</head>

<body>

<div class="hero">
  <h1>REWIND</h1>
  <p>1995 — 2005</p>
</div>

<div class="section">
  <h2>Deep Dives</h2>

  <div class="card" onclick="openOverlay('WRC')">WRC</div>
  <div class="card" onclick="openOverlay('Motocross')">Motocross</div>
  <div class="card" onclick="openOverlay('Wrestling')">Wrestling</div>
  <div class="card" onclick="openOverlay('Nu Metal')">Nu Metal</div>
  <div class="card" onclick="openOverlay('Premier League')">Premier League</div>
</div>

<div class="overlay" id="overlay">
  <button class="close" onclick="closeOverlay()">CLOSE</button>
  <h1 id="title"></h1>
